{
	"name": "pi-thread-goal",
	"version": "0.5.3",
	"description": "Persistent Claude-style /goal workflows for Pi with branch-aware state and automatic cross-turn continuation.",
	"type": "module",
	"license": "MIT",
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"pi-coding-agent",
		"goal"
	],
	"pi": {
		"extensions": [
			"./extensions/index.ts"
		]
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"validate:workflows": "node scripts/validate-workflows.mjs",
		"test": "vitest run",
		"benchmark": "vitest bench --run",
		"verify:performance": "tsx scripts/verify-state-reconstruction.ts",
		"test:coverage": "vitest run --coverage",
		"test:e2e-pi": "cross-env PI_E2E=1 vitest run tests/pi-live.e2e.test.ts",
		"test:packed": "node scripts/verify-packed-extension.mjs"
	},
	"files": [
		"extensions",
		"src",
		"README.md",
		"SECURITY.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"peerDependencies": {
		"@earendil-works/pi-ai": ">=0.74.2 <=0.80.7",
		"@earendil-works/pi-coding-agent": ">=0.74.2 <=0.80.7",
		"typebox": ">=1.1.24 <=1.1.38"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@earendil-works/pi-ai": "0.80.7",
		"@earendil-works/pi-coding-agent": "0.80.7",
		"@types/node": "^24.10.1",
		"@vitest/coverage-v8": "4.1.9",
		"actionlint": "2.0.6",
		"cross-env": "^10.1.0",
		"tsx": "^4.20.6",
		"typebox": "1.1.38",
		"typescript": "^7.0.2",
		"vitest": "^4.1.8",
		"yaml": "2.9.0"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
